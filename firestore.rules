rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== WORKSTATIONS =====
    // Anyone can read available workstations
    // Anyone can update when borrowing (set status to "borrowed")
    // Only admins can create, delete, or return
    match /workstations/{wsId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null || request.resource.data.status == "borrowed";
      allow delete: if request.auth != null;
    }

    // ===== BORROW RECORDS =====
    // Anyone can create a borrow record
    // Only admins can read and update (for returning)
    match /borrowRecords/{recordId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ===== ADMINS =====
    match /admins/{adminId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
